# ── Application ─────────────────────────────────
SECRET_KEY=change_this_to_a_very_long_random_secret_key_256bits
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# AES-256 key for encrypting DB passwords (32 url-safe base64 chars)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_this_to_32_byte_base64_key=

# ── PostgreSQL (Platform Metadata DB) ────────────
POSTGRES_USER=vanna_admin
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=vanna_platform

# Built automatically inside Docker from POSTGRES_* vars above.
# For local dev (outside Docker), set these explicitly:
DATABASE_URL=postgresql+asyncpg://vanna_admin:change_this_strong_password@localhost:5432/vanna_platform
SYNC_DATABASE_URL=postgresql+psycopg2://vanna_admin:change_this_strong_password@localhost:5432/vanna_platform

# ── Redis ────────────────────────────────────────
REDIS_PASSWORD=change_this_redis_password
# Built automatically inside Docker. For local dev:
REDIS_URL=redis://:change_this_redis_password@localhost:6379/0

# ── Vanna AI Microservice ─────────────────────────
# Resolved automatically inside Docker. For local dev:
VANNA_SERVICE_URL=http://localhost:8001

# ── OpenAI (used by Vanna AI) ────────────────────
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
VANNA_MODEL=gpt-4o-mini

# ── Rate Limiting ────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
API_RATE_LIMIT_PER_MINUTE=100

# ── CORS Origins ─────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80

# ── Environment ──────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
